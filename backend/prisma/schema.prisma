generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  rollNo       String   @unique
  isVerified   Boolean    @default(false)
  emailVerified   Boolean   @default(false)
  emailOtp        String?
  emailOtpExpiry  DateTime?
  status       UserStatus @default(UNVERIFIED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?

  // Relations...
  alumniProfile AlumniProfile?
  jobs          Job[]
  events        Event[]
  registrations EventRegistration[]

  // Chat relations
  conversations ConversationMember[]
  sentMessages  Message[]

  // Connection relations
  sentConnectionRequests     ConnectionRequest[] @relation("SentRequests")
  receivedConnectionRequests ConnectionRequest[] @relation("ReceivedRequests")
  connectionsAsUser          UserConnection[]    @relation("UserConnections")
  connectionsAsConnection    UserConnection[]    @relation("ConnectionUsers")

  // Story relations
  stories Story[]

  @@map("users")
}

// ─── Chat Models ──────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isSeen         Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model AlumniProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  batchYear     Int
  department    String
  rollNo        String?
  company       String?
  jobTitle      String?
  linkedinUrl   String?
  photoUrl      String?
  bio           String?
  location      String?
  skills        String[]
  contactPublic Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("alumni_profiles")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String?
  imageUrl    String?
  isActive    Boolean  @default(true)

  // (Audience ke liye)
  targetAudience String @default("ALL") 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // (Jo pehle se tha)
  postedBy    User     @relation(fields: [postedById], references: [id], onDelete: Cascade)
  postedById  String

  registrations EventRegistration[]

  @@map("events")
}

// ─── Connection Models ─────────────────────────────────────────────────────────

/// Pending / accepted / rejected connection requests between two users.
model ConnectionRequest {
  id         String            @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus  @default(PENDING)
  createdAt  DateTime          @default(now())

  sender   User @relation("SentRequests",      fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests",   fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId])
  @@map("connection_requests")
}

/// Bidirectional adjacency list — one row per direction (A→B and B→A).
/// Both rows are always inserted together in a transaction on accept.
model UserConnection {
  userId       String
  connectionId String
  createdAt    DateTime @default(now())

  user       User @relation("UserConnections",  fields: [userId],       references: [id], onDelete: Cascade)
  connection User @relation("ConnectionUsers",   fields: [connectionId], references: [id], onDelete: Cascade)

  @@id([userId, connectionId])
  @@index([userId])
  @@index([connectionId])
  @@map("user_connections")
}

enum Role {
  ADMIN
  ALUMNI
  STUDENT
}

enum UserStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum StoryStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- Job Model ---
model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  location    String
  type        String   // Full-time, Internship, etc.
  description String
  applyLink   String?  // Agar koi Google Form link hai
  postedBy    User     @relation(fields: [postedById], references: [id], onDelete: Cascade)
  postedById  String
  createdAt   DateTime @default(now())
}

// --- Event Registration Model (New) ---
model EventRegistration {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  createdAt DateTime @default(now())

  @@unique([userId, eventId]) // Taaki ek banda do baar register na kare
}

// --- Story Model ---
model Story {
  id        String      @id @default(uuid())
  title     String
  content   String      @db.Text
  status    StoryStatus @default(PENDING)
  authorId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("stories")
}
